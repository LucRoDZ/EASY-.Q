# ========================================
# EASY.Q Backend Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — only .env.example should be tracked

# ========================================
# Database
# ========================================
# PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
# Development: postgresql+asyncpg://postgres:postgres@localhost:5432/easyq
# Production: Use managed database URL (Railway, Supabase, etc.)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/easyq

# ========================================
# Redis
# ========================================
# Redis connection URL
# Used for: session storage (2h TTL), menu cache (5min), OCR cache (24h), KDS pub/sub
# Format: redis://host:port/db
# Development: redis://localhost:6379/0
# Production: Use managed Redis URL (Railway, Upstash, etc.)
REDIS_URL=redis://localhost:6379/0

# ========================================
# Authentication - Clerk
# ========================================
# Clerk secret key for JWT verification (backend)
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...

# Clerk JWKS endpoint for JWT signature verification
# Format: https://<your-clerk-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Clerk webhook signing secret for user lifecycle events (user.created, user.deleted)
# Get from: https://dashboard.clerk.com → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ========================================
# AI - Google Gemini
# ========================================
# Google Gemini API key for OCR (PDF → menu extraction) and chatbot
# Get from: https://aistudio.google.com/app/apikey
# Model used: gemini-2.5-flash
# NOTE: config.py currently uses GOOGLE_API_KEY — both names supported
GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...  # Alternative name (REBUILD_ROADMAP spec)

# ========================================
# Payment - Stripe
# ========================================
# Stripe secret key (backend)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe publishable key (shared with frontend via API)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret (for /api/v1/payments/webhook)
# Get from: https://dashboard.stripe.com/test/webhooks → Add endpoint
# Endpoint URL: https://your-domain/api/v1/payments/webhook
# Events: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect client ID (for multi-restaurant payouts)
# Get from: https://dashboard.stripe.com/settings/connect
# Optional — only required if using Stripe Connect for restaurant payouts
STRIPE_CONNECT_CLIENT_ID=ca_...

# Stripe Pro plan Price ID (for subscription checkout)
# Get from: https://dashboard.stripe.com/products → select Pro plan → copy Price ID
# Used by POST /api/v1/subscriptions/create-checkout
STRIPE_PRO_PRICE_ID=price_...

# Stripe billing webhook signing secret (for /api/v1/subscriptions/webhook)
# Get from: https://dashboard.stripe.com/test/webhooks → Add endpoint
# Events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...

# ========================================
# KDS - Kitchen Display System
# ========================================
# Simple static token for KDS authentication (not Clerk-based)
# Must be set to a long random secret in production
# Generate: openssl rand -hex 32
KDS_SECRET_TOKEN=kds-dev-token-change-in-production

# ========================================
# Monitoring - Sentry
# ========================================
# Sentry DSN for error tracking (backend). Leave empty to disable.
# Get from: https://sentry.io → New Project → FastAPI
SENTRY_DSN=

# ========================================
# Email - Resend
# ========================================
# Resend API key for transactional emails
# Get from: https://resend.com/api-keys
# Used for: welcome, payment receipts, low NPS alerts, weekly digest
RESEND_API_KEY=re_...

# Sender email address (must be verified in Resend)
# Recommended: noreply@your-domain.com
RESEND_FROM_EMAIL=noreply@easy-q.app

# ========================================
# Storage - Cloudflare R2 (S3-compatible)
# ========================================
# R2 bucket name
R2_BUCKET_NAME=easyq

# R2 API token access key
# Get from: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=...

# R2 API token secret key
R2_SECRET_ACCESS_KEY=...

# R2 S3-compatible endpoint URL
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://abc123.r2.cloudflarestorage.com

# R2 public URL (optional custom domain for public objects)
# Only set if you have a custom domain configured for public bucket access
# Example: https://cdn.easy-q.app
# Leave empty to use presigned URLs for all objects
R2_PUBLIC_URL=

# ========================================
# Server Configuration
# ========================================
# Base URL for the backend API
# Development: http://localhost:8000
# Production: https://api.your-domain.com
BASE_URL=http://localhost:8000

# Local storage directory for uploads (fallback if R2 not configured)
# Files: PDFs, temporary uploads, QR codes
# Default: ./storage
STORAGE_DIR=./storage

# ========================================
# CORS & Frontend
# ========================================
# Allowed CORS origins (comma-separated, no spaces)
# Development: http://localhost:5173,http://localhost:3000
# Production: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL for redirects (e.g., QR code scans → frontend menu page)
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# ========================================
# Observability - Langfuse (Optional)
# ========================================
# Langfuse public key for LLM observability
# Get from: https://cloud.langfuse.com → Settings → API Keys
# Optional — leave empty to disable Langfuse tracing
LANGFUSE_PUBLIC_KEY=

# Langfuse secret key
LANGFUSE_SECRET_KEY=

# Langfuse host URL
# Default: https://cloud.langfuse.com
# Self-hosted: https://your-langfuse-instance.com
LANGFUSE_HOST=https://cloud.langfuse.com

# ========================================
# Environment Flag (Optional)
# ========================================
# Set to "true" in production for production-only behaviors
# Used for: disabling debug logs, enabling strict security headers, etc.
# IS_PRODUCTION=true

# ========================================
# Development Notes
# ========================================
# 1. Quick start (local dev):
#    - PostgreSQL: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=easyq postgres:16
#    - Redis: docker run -d -p 6379:6379 redis:7
#
# 2. Required for core functionality:
#    - DATABASE_URL, REDIS_URL, GOOGLE_API_KEY, STRIPE_SECRET_KEY
#
# 3. Optional (graceful degradation):
#    - R2_* (falls back to local STORAGE_DIR)
#    - RESEND_API_KEY (email sending disabled, logs warning)
#    - LANGFUSE_* (tracing disabled)
#    - CLERK_* (if auth not yet implemented)
#
# 4. Security:
#    - NEVER commit .env to git
#    - Use different keys for dev/test/prod
#    - Rotate secrets regularly in production
#    - Use Railway/Render secret management in production
