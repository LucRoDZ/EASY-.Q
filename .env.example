# EASY.Q Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================================================
# Core Application
# ============================================================================

# Base URL of the backend API (used for generating QR codes, emails, etc.)
# Production: https://api.easy-q.app
# Development: http://localhost:8000
BASE_URL=http://localhost:8000

# Frontend URL (used for redirects from QR code scans)
# Production: https://easy-q.app
# Development: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Allowed CORS origins (comma-separated)
# Production: https://easy-q.app,https://www.easy-q.app
# Development: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Database
# ============================================================================

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
# Development: postgresql+asyncpg://postgres:postgres@localhost:5432/easyq
# Production: Use managed PostgreSQL (Railway, Supabase, etc.)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/easyq

# ============================================================================
# Redis Cache & Pub/Sub
# ============================================================================

# Redis connection URL
# Format: redis://host:port/db
# Development: redis://localhost:6379/0
# Production: Use managed Redis (Upstash, Railway, etc.)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# AI Services (Gemini)
# ============================================================================

# Google Gemini API key (REQUIRED for OCR and chatbot)
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# File Storage (Cloudflare R2)
# ============================================================================

# R2 bucket name (default: easyq)
R2_BUCKET_NAME=easyq

# R2 API credentials
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 endpoint URL
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# Optional: Custom public domain for R2 bucket (e.g., https://cdn.easy-q.app)
# Leave empty to use presigned URLs for all files
R2_PUBLIC_URL=

# ============================================================================
# Transactional Email (Resend)
# ============================================================================

# Resend API key (REQUIRED for sending emails)
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# From email address (must be verified in Resend)
# Format: noreply@yourdomain.com
RESEND_FROM_EMAIL=noreply@easy-q.app

# ============================================================================
# Payment Processing (Stripe)
# ============================================================================

# Stripe secret key (REQUIRED for payment processing)
# Get yours at: https://dashboard.stripe.com/apikeys
# Test mode: sk_test_...
# Live mode: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe publishable key (used in frontend)
# Test mode: pk_test_...
# Live mode: pk_live_...
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe webhook signing secret (REQUIRED for webhook verification)
# Get this from: Stripe Dashboard → Developers → Webhooks
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# Observability (Langfuse) — OPTIONAL
# ============================================================================

# Langfuse public key (for LLM observability and analytics)
# Get yours at: https://cloud.langfuse.com
# Leave empty to disable Langfuse tracking
LANGFUSE_PUBLIC_KEY=

# Langfuse secret key
LANGFUSE_SECRET_KEY=

# Langfuse host (default: https://cloud.langfuse.com)
# Use self-hosted instance if you have one
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================================
# Local Storage (Development Only)
# ============================================================================

# Local storage directory for PDFs, QR codes, logos
# Only used in development if R2 is not configured
# Production: Always use R2/S3
STORAGE_DIR=./storage

